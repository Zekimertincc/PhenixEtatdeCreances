<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.zeki.merger.controller.MainController"
            styleClass="root-pane">

    <!-- ===== TOP — black header band ===== -->
    <top>
        <VBox styleClass="header-band">
            <Label text="CABINET PHÉNIX" styleClass="app-title"/>
        </VBox>
    </top>

    <!-- ===== CENTER — tabbed content ===== -->
    <center>
        <TabPane styleClass="main-tabs" tabClosingPolicy="UNAVAILABLE">

            <!-- ── Tab 1: Operations ── -->
            <Tab text="OPÉRATIONS">
                <BorderPane>

                    <center>
                        <VBox styleClass="content-box" spacing="10">
                            <padding><Insets top="20" right="24" bottom="12" left="24"/></padding>

                            <!-- FILES CARD -->
                            <HBox styleClass="files-card" alignment="CENTER_LEFT" spacing="12">
                                <VBox HBox.hgrow="ALWAYS" spacing="6">
                                    <Label text="Fichiers configurés" styleClass="files-card-title"/>
                                    <HBox fx:id="badgesBox" spacing="6" alignment="CENTER_LEFT"/>
                                    <Label fx:id="missingFilesLabel" styleClass="missing-label"
                                           text="" visible="false" managed="false"/>
                                </VBox>
                                <Button text="⚙ Configurer" styleClass="secondary-btn"
                                        onAction="#openFileConfig"/>
                            </HBox>

                            <!-- ACTIONS GRID (populated programmatically in initialize()) -->
                            <GridPane fx:id="actionsGrid" hgap="10" vgap="10">
                                <columnConstraints>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                                    <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                                </columnConstraints>
                            </GridPane>

                            <!-- PROGRESS BAR -->
                            <ProgressBar fx:id="progressBar"
                                         maxWidth="Infinity"
                                         prefHeight="16"
                                         styleClass="merge-progress"/>

                            <!-- LOG AREA -->
                            <Label text="LOG" styleClass="field-label"/>
                            <TextArea fx:id="logArea"
                                      editable="false"
                                      wrapText="false"
                                      styleClass="log-area"
                                      VBox.vgrow="ALWAYS"/>
                        </VBox>
                    </center>

                    <bottom>
                        <HBox fx:id="statusBar"
                              spacing="12"
                              alignment="CENTER_LEFT"
                              styleClass="status-bar">
                            <padding><Insets top="8" right="16" bottom="8" left="16"/></padding>
                            <Label fx:id="statusLabel"
                                   styleClass="status-label"
                                   HBox.hgrow="ALWAYS"/>
                            <Button fx:id="openFileBtn"
                                    text="Open File"
                                    styleClass="open-btn"
                                    onAction="#openFile"/>
                        </HBox>
                    </bottom>

                </BorderPane>
            </Tab>

            <!-- ── Tab 2: Dashboard ── -->
            <Tab text="DASHBOARD">
                <fx:include fx:id="dashboard" source="dashboard.fxml"/>
            </Tab>

        </TabPane>
    </center>

</BorderPane>
