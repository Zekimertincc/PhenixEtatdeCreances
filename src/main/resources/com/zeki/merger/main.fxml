<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.zeki.merger.controller.MainController"
      styleClass="root-pane">

    <!-- ===== LEFT SIDEBAR (200px fixed) ===== -->
    <VBox styleClass="sidebar" prefWidth="200" minWidth="200" maxWidth="200">

        <VBox styleClass="sidebar-logo" alignment="CENTER" spacing="4">
            <padding><Insets top="24" bottom="16" left="0" right="0"/></padding>
            <Label text="Cabinet Phénix" styleClass="sidebar-logo-title"/>
            <Label text="v1.0.0" styleClass="sidebar-logo-sub"/>
        </VBox>

        <Label text="PRINCIPAL" styleClass="nav-section-label">
            <VBox.margin><Insets top="8" left="16" bottom="4"/></VBox.margin>
        </Label>
        <Button fx:id="navOperations" text="⊞  Opérations" maxWidth="Infinity"
                styleClass="nav-item" onAction="#showOperations"/>
        <Button fx:id="navDashboard"  text="▦  Dashboard"  maxWidth="Infinity"
                styleClass="nav-item" onAction="#showDashboard"/>
        <Button fx:id="navHistorique" text="📅  Historique" maxWidth="Infinity"
                styleClass="nav-item" onAction="#showHistorique"/>

        <Region prefHeight="1" minHeight="1" maxHeight="1" styleClass="sidebar-divider-line">
            <VBox.margin><Insets top="8" bottom="8"/></VBox.margin>
        </Region>

        <Label text="PARAMÈTRES" styleClass="nav-section-label">
            <VBox.margin><Insets left="16" bottom="4"/></VBox.margin>
        </Label>
        <Button fx:id="navConfig" text="⚙  Configuration" maxWidth="Infinity"
                styleClass="nav-item" onAction="#showConfig"/>

        <Region VBox.vgrow="ALWAYS"/>

        <Region prefHeight="1" minHeight="1" maxHeight="1" styleClass="sidebar-divider-line"/>
        <Button fx:id="navLogFull" text="⌨  Log complet" maxWidth="Infinity"
                styleClass="nav-item" onAction="#showLogFull"/>
    </VBox>

    <!-- ===== RIGHT MAIN AREA ===== -->
    <BorderPane HBox.hgrow="ALWAYS">

        <top>
            <HBox styleClass="top-bar" alignment="CENTER_LEFT" prefHeight="48" minHeight="48">
                <padding><Insets left="20" right="20"/></padding>
                <Label fx:id="pageTitle" text="Opérations" styleClass="page-title"/>
            </HBox>
        </top>

        <center>
            <StackPane>

                <!-- Page 1: Opérations -->
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                            styleClass="main-scroll-pane" VBox.vgrow="ALWAYS">
                <VBox fx:id="pageOperations" styleClass="content-box" spacing="10">
                    <padding><Insets top="16" right="24" bottom="12" left="24"/></padding>

                    <HBox styleClass="files-card" alignment="CENTER_LEFT" spacing="12">
                        <VBox HBox.hgrow="ALWAYS" spacing="6">
                            <Label text="Fichiers configurés" styleClass="files-card-title"/>
                            <FlowPane fx:id="badgesBox" hgap="6" vgap="4" alignment="CENTER_LEFT"/>
                            <Label fx:id="missingFilesLabel" styleClass="missing-label"
                                   text="" visible="false" managed="false"/>
                        </VBox>
                        <Button text="⚙ Configurer" styleClass="secondary-btn"
                                onAction="#openFileConfig"/>
                    </HBox>

                    <GridPane fx:id="actionsGrid" hgap="10" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50"/>
                        </columnConstraints>
                    </GridPane>

                    <ProgressBar fx:id="progressBar" maxWidth="Infinity" prefHeight="16"
                                 styleClass="merge-progress"/>

                    <Label text="LOG" styleClass="field-label"/>
                    <TextArea fx:id="logArea" editable="false" wrapText="false"
                              styleClass="log-area" prefHeight="90" maxHeight="90"/>

                </VBox>
                </ScrollPane>

                <!-- Page 2: Dashboard (populated programmatically) -->
                <VBox fx:id="pageDashboard" styleClass="content-box" visible="false" managed="false"/>

                <!-- Page 3: Historique (populated programmatically) -->
                <VBox fx:id="pageHistorique" styleClass="content-box" visible="false" managed="false"/>

                <!-- Page 4: Configuration -->
                <VBox fx:id="pageConfig" styleClass="content-box" visible="false" managed="false" spacing="16">
                    <padding><Insets top="16" right="24" bottom="12" left="24"/></padding>
                    <VBox fx:id="configFormBox" spacing="12"/>
                    <HBox alignment="CENTER_RIGHT">
                        <Button text="Enregistrer" styleClass="run-btn" onAction="#saveConfig"/>
                    </HBox>
                </VBox>

            </StackPane>
        </center>

        <bottom>
            <HBox fx:id="statusBar" spacing="10" alignment="CENTER_LEFT"
                  visible="false" managed="false"
                  styleClass="status-bar-box">
                <padding><Insets top="6" right="12" bottom="6" left="20"/></padding>
                <Label fx:id="statusLabel" styleClass="status-label" HBox.hgrow="ALWAYS" wrapText="true"/>
                <Button fx:id="openFileBtn" text="📂 Ouvrir" styleClass="open-file-btn" onAction="#openFile"/>
            </HBox>
        </bottom>

    </BorderPane>
</HBox>
